{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"],
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_22"]
        },
        "install": {
          "cmds": ["cd webapp && npm install"]
        },
        "build": {
          "cmds": ["cd webapp && npm run build"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd webapp && npm run start"
  }
}
