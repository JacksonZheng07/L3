# L3 Webapp — Environment Variables
# Copy this file to .env and fill in values for local development.
# In production (Railway), set these in the dashboard under Variables.

# Allium on-chain intelligence API key (optional — enables on-chain scoring signals)
ALLIUM_API_KEY=

# Discord bot notifications (optional — enables alerts to a Discord channel)
# 1. Create a bot at https://discord.com/developers/applications
# 2. Invite it with Send Messages + Embed Links permissions
# 3. Set the bot token and target channel ID below
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
